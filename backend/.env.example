DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
CLERK_ISSUER=
CLERK_JWKS_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AI_PROVIDER=anthropic
AI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# -----------------------------------------------------------------------------
# CORS / connection
# FRONTEND_URL: origin the frontend runs on (allowed by backend CORS)
# BACKEND_URL : public URL this backend is reachable at (used in emails/links)
# Local dev:  http://localhost:3000 / http://localhost:8000
# Deployed:   https://your-frontend.vercel.app / https://your-backend.onrender.com
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Email notifications (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ADMIN_EMAIL=

# Slack / webhook alerts (optional — leave blank to disable)
SLACK_WEBHOOK_URL=
NOTIFY_WEBHOOK_URL=

